// 초안 스키마 — [[구현 방식]] 4.1 참고. Phase 1 최소 테이블만 정의, 실제 마이그레이션은 이후 이슈에서 진행.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id              Int                    @id @default(autoincrement())
  name            String
  supported       Boolean                @default(false)
  departments     Department[]
  colleges        College[]
  profiles        Profile[]
  catalogChecks   CatalogCatholicCheck[]
  courseOfferings CourseOffering[]

  @@map("universities")
}

// 계열(College)은 학과 상위 그룹핑 단위 — 대학 공식 계열번호를 그대로 id로 사용(autoincrement 아님).
// 크롤러가 학과 사이트 URL을 발견/조직하는 데 쓰인다([[대학_학사_데이터_크롤링_파이프라인_및_폐지_과목_처리_설계서_v2]] 1.2).
model College {
  id           Int          @id
  universityId Int          @map("university_id")
  name         String
  campus       String       @default("성심") // '성심' | '성의' | '성신'
  university   University   @relation(fields: [universityId], references: [id])
  departments  Department[]

  @@index([universityId])
  @@map("colleges")
}

model Department {
  id                     Int                            @id @default(autoincrement())
  universityId           Int                            @map("university_id")
  collegeId              Int?                           @map("college_id")
  name                   String
  catalogReady           Boolean                        @default(false) @map("catalog_ready")
  // 아래 3개 필드는 catalog/catholic-university 크롤러가 학과 사이트를 찾아가는 데 쓰는 실제 확인된 값
  // ([[대학_학사_데이터_크롤링_파이프라인_및_폐지_과목_처리_설계서_v2]] 1.3, 가톨릭대_학과_계열_매핑.xlsx 기준).
  domainSlug             String?                        @map("domain_slug")
  baseUrl                String?                        @map("base_url")
  urlPattern             String                         @default("standard") @map("url_pattern") // 'standard' | 'subdirectory' | 'other-campus'
  // 학사정보(졸업요건) 페이지가 표준 {baseUrl}/{domainSlug}/course/academic.do 경로가 아닌 학과용 override
  // (스니펫 조사서 패턴 ⑦). 표준 경로를 쓰는 대부분 학과는 null — 크롤러가 도메인/슬러그로 조립한다.
  academicRequirementUrl String?                        @map("academic_requirement_url")
  // 자유전공학부/융합전공학부/교직과/학부대학처럼 학위를 수여하는 실제 "학과"가 아니라 행정단위인 경우 true
  // (설계서 v2·스키마설계노트 v3 패턴 ⑱). true인 Department는 CatalogGraduationRequirement를 갖지 않는다.
  isAdministrativeUnit   Boolean                        @default(false) @map("is_administrative_unit")
  university             University                     @relation(fields: [universityId], references: [id])
  college                College?                       @relation(fields: [collegeId], references: [id])
  tracks                 Track[]
  catalogCourses         CatalogCourse[]
  graduationRequirements CatalogGraduationRequirement[]
  majorProfiles          Profile[]                      @relation("MajorDepartment")
  secondMajorProfiles    Profile[]                      @relation("SecondMajorDepartment")
  minorProfiles          Profile[]                      @relation("MinorDepartment")
  crossMajorCreditRecognitions CrossMajorCreditRecognition[]

  @@index([universityId])
  @@index([collegeId])
  @@map("departments")
}

model Track {
  id                       Int                            @id @default(autoincrement())
  departmentId             Int                            @map("department_id")
  name                     String
  // 구 "트랙별 필수과목 리스트" 모델의 잔재 필드 — CatalogGraduationRequirement(JSON 기반)로 대체된 뒤
  // 트랙 자체는 유지되지만 트랙 단위 필수과목 수 개념이 없는 학과(mtc/is 등)가 있어 nullable로 완화.
  requiredCourseCount      Int?                           @map("required_course_count")
  department               Department                     @relation(fields: [departmentId], references: [id])
  majorTrackProfiles       Profile[]                      @relation("MajorTrack")
  secondMajorTrackProfiles Profile[]                      @relation("SecondMajorTrack")
  graduationRequirements   CatalogGraduationRequirement[]

  @@index([departmentId])
  @@map("tracks")
}

enum ProgramType {
  DOUBLE_MAJOR // 복수전공(제2전공)
  DEEPENED_MAJOR // 전공심화(단수전공)
}

model Profile {
  id            Int    @id @default(autoincrement())
  sessionId     String @unique @map("session_id")
  admissionYear Int    @map("admission_year")
  universityId  Int    @map("university_id")

  majorDepartmentId Int         @map("major_department_id")
  majorTrackId      Int?        @map("major_track_id")
  programType       ProgramType @map("program_type")

  secondMajorDepartmentId Int? @map("second_major_department_id")
  secondMajorTrackId      Int? @map("second_major_track_id")

  minorDepartmentId Int?    @map("minor_department_id")
  hasMicroDegree    Boolean @default(false) @map("has_micro_degree")

  syncedAt DateTime? @map("synced_at")

  university            University  @relation(fields: [universityId], references: [id])
  majorDepartment       Department  @relation("MajorDepartment", fields: [majorDepartmentId], references: [id])
  majorTrack            Track?      @relation("MajorTrack", fields: [majorTrackId], references: [id])
  secondMajorDepartment Department? @relation("SecondMajorDepartment", fields: [secondMajorDepartmentId], references: [id])
  secondMajorTrack      Track?      @relation("SecondMajorTrack", fields: [secondMajorTrackId], references: [id])
  minorDepartment       Department? @relation("MinorDepartment", fields: [minorDepartmentId], references: [id])

  semesters       Semester[]
  retakeGroups    RetakeGroup[]
  graduationExtra GraduationExtra?

  @@index([universityId])
  @@index([majorDepartmentId])
  @@index([secondMajorDepartmentId])
  @@index([minorDepartmentId])
  @@map("profiles")
}

model Semester {
  id        Int     @id @default(autoincrement())
  profileId Int     @map("profile_id")
  label     String
  sortOrder Int     @map("sort_order")
  active    Boolean @default(false)

  // Profile은 세션 단위 임시 데이터라, 세션 만료/탈퇴 시 하위 학기·과목도 함께 정리되어야 한다.
  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  courses Course[]

  @@index([profileId])
  @@map("semesters")
}

enum CourseSource {
  CRAWL
  TEXT_PASTE
  MANUAL
}

model Course {
  id                          Int          @id @default(autoincrement())
  semesterId                  Int          @map("semester_id")
  name                        String
  code                        String?
  category                    String?
  credit                      Int
  general                     Boolean      @default(false)
  substitutionCatalogCourseId Int?         @map("substitution_catalog_course_id")
  source                      CourseSource @default(MANUAL)
  // CourseOffering 매칭 시점의 "개설전공(과)" 원문(FEAT#19). 졸업계산에서 중핵교양필수 과목이
  // 학생 본인 전공 소속으로 개설된 경우 전공학점으로 재분류하는 데 쓰인다(Department FK 아님,
  // CourseOffering과 동일하게 원문 텍스트로만 보관 — 요청 시점 매칭이라 학과가 나중에 바뀌어도 안전).
  offeringDepartmentName      String?      @map("offering_department_name")
  // CourseOffering의 "외국어 강의여부" 원문(예: "A형(영)") — 외국어로 진행되는 강의임을 STEP1에 표시.
  foreignLanguageType         String?      @map("foreign_language_type")
  // 타전공학점인정 제도(CrossMajorCreditRecognition) 신청 여부 — 검증 화면에서 사용자가 직접 토글.
  // true면 graduation 계산에서 이 과목의 category를 전공(제1전공선택 상당)으로 취급한다(이슈 #51).
  crossMajorRecognized        Boolean      @default(false) @map("cross_major_recognized")

  semester     Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  // 대체인정 연결된 요람 과목이 삭제되어도 수강기록 자체는 남기고 연결만 해제한다.
  substitution CatalogCourse? @relation(fields: [substitutionCatalogCourseId], references: [id], onDelete: SetNull)

  @@index([semesterId])
  @@index([substitutionCatalogCourseId])
  @@map("courses")
}

model CatalogCourse {
  id                Int    @id @default(autoincrement())
  departmentId      Int    @map("department_id")
  name              String
  code              String
  category          String
  credit            Int
  admissionYearFrom Int    @map("admission_year_from")
  admissionYearTo   Int?   @map("admission_year_to")

  department         Department @relation(fields: [departmentId], references: [id])
  substitutedCourses Course[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("catalog_courses")
}

// 트리니티(uportal) 학기별 개설과목 리스트 엑셀을 수동 임포트한 데이터([[issue/[FEAT#19] 크롤링 과목 자동 과목코드 매칭 (요람 대조)]]).
// 요람(CatalogCourse)과 달리 "그 학기에 실제로 개설된 강좌"라 담당교수/분반이 있고, 같은 code를
// 여러 학과가 서로 다른 분반으로 공유 개설하는 경우도 있어 학과 FK 없이 원문 학과명만 저장한다.
// 에브리타임 크롤러가 과목코드/학점을 못 얻는 문제를 이 데이터와 (과목명 + 담당교수) 매칭으로 보완한다.
model CourseOffering {
  id                  Int     @id @default(autoincrement())
  universityId        Int     @map("university_id")
  year                Int
  term                String // '1학기' | '2학기' | '하계계절학기' | '동계계절학기'
  code                String
  name                String
  section             String
  professor           String
  credit              Int
  category            String
  departmentName      String  @map("department_name") // 엑셀 원문("개설전공(과)") 그대로, Department FK 아님
  foreignLanguageType String? @map("foreign_language_type") // 엑셀 "외국어 강의여부" 원문(예: "A형(영)"), 빈칸이면 null

  university University @relation(fields: [universityId], references: [id])

  @@unique([universityId, year, term, code, section])
  @@index([universityId, year, term, name])
  @@map("course_offerings")
}

// 가톨릭대 타전공학점인정 제도(https://www.catholic.ac.kr/ko/campuslife/notice.do?mode=view&articleNo=272670)
// 안내 엑셀("타전공_학점인정_교과목_목록(2026.06).xlsx", 8개 시트) 전량 임포트. 학생 본인 전공
// (recognizingDepartment) 입장에서, 다른 학과(offeringDepartmentName)가 개설한 특정 과목을 들으면
// 전공학점으로 인정해주는 제도 — Course FK가 아니라 (학과, 과목명, 과목코드) 조합으로 매칭한다
// (엑셀 자체가 요람 DB와 별도로 관리되는 목록이라 CatalogCourse와 직접 연결되지 않음).
model CrossMajorCreditRecognition {
  id                     Int     @id @default(autoincrement())
  recognizingDepartmentId Int    @map("recognizing_department_id")
  offeringDepartmentName String  @map("offering_department_name") // 엑셀 "개설학과" 원문, Department FK 아님(계열/전공명이 섞여있어 매칭 불안정)
  courseName             String  @map("course_name")
  courseCode             String  @map("course_code") // 과목코드 변경 이력은 "06540->06549"처럼 원문 그대로 저장
  note                   String? // 엑셀 "비고"(적용시기, 예외조건 등)
  seriesLabel            String? @map("series_label") // 엑셀 시트/계열 라벨(예: "인문계열", "AI전자정보융합대학") — 정보성

  recognizingDepartment Department @relation(fields: [recognizingDepartmentId], references: [id])

  @@index([recognizingDepartmentId, courseName])
  @@map("cross_major_credit_recognitions")
}

// 43개 학과 전수조사(가톨릭대_학과별_졸업요건_스키마_v3.xlsx) 결과 반영. 졸업요건은 학과 단위가 아니라
// (학과 × 트랙 × 전공유형 × 적용학번/졸업시점) 조합 단위로 갈리고, "대체 옵션 중 택1"과 "전원 필수 병렬요건"이
// 섞여 있는 학과가 많아(스키마설계노트 v3 패턴 ①~⑳) 아래처럼 축을 명시적으로 분리했다. JSON 필드는 모두
// "null=미확인" vs "확인된 값(빈 배열 포함)" 을 구분해서 채운다 — 빈 배열은 "조사해서 해당없음을 확인함"을
// 의미하고, null은 "아직 조사 못함"을 의미한다(패턴 ⑥).
//
// substitutionRules: Array<{ type: string; condition: string; scope?: 'FULL'|'PARTIAL'; waives?: number|null;
//   trackRestriction?: string|null; note?: string }> — 졸업시험/논문 등 기본요건을 "택1로 대체"할 수 있는 옵션들.
// mandatoryRequirements: Array<{ type: string; condition: string; note?: string }> — 대체가 아니라 전원이
//   추가로 반드시 충족해야 하는 병렬요건(패턴 ⑤⑨⑪). substitutionRules와 AND 관계.
// scoreItems: Array<{ label: string; weightPercent?: number; maxScore?: number; note?: string }> — 점수누적형
//   (패턴 ⑬)의 항목별 배점. pointThreshold(총점 기준)와 함께 쓰인다.
model CatalogGraduationRequirement {
  id           Int  @id @default(autoincrement())
  departmentId Int  @map("department_id")
  // 트랙별로 요건이 갈리는 학과(mtc/is 등, 패턴 ①)만 채움. 트랙 구분 자체가 없는 학과는 null.
  trackId      Int? @map("track_id")

  // 적용학번 축(패턴 ②⑧) — admissionYearFrom/To는 파싱 가능한 경우의 최선 근사치이고, cohortLabel이
  // 원문 그대로의 근거(source of truth)다. 학번군 세분화 정도가 학과마다 달라 고정 enum 대신 자유 구간으로 둔다.
  admissionYearFrom  Int?             @map("admission_year_from")
  admissionYearTo    Int?             @map("admission_year_to")
  cohortLabel        String           @map("cohort_label")
  // 정보통신전자공학부처럼 "졸업시점" 기준으로 제도가 통째로 바뀌는 경우(패턴 ⑫) — basis가 GRADUATION_DATE면
  // admissionYearFrom/To 대신 graduationDateFrom("2025-08" 형태)이 실제 적용 기준이다.
  basis              RequirementBasis @default(ADMISSION_YEAR) @map("basis")
  graduationDateFrom String?          @map("graduation_date_from")

  // 제1전공(전공심화 포함) vs 복수전공자 요건이 갈리는 경우(패턴 ⑭, 예: 생명공학과)만 ALL이 아닌 값을 쓴다.
  scope RequirementScope @default(ALL) @map("scope")

  totalCreditMin  Int?  @map("total_credit_min")
  creditBreakdown Json? @map("credit_breakdown")

  // 시험/논문 단일 판정이 아니라 여러 활동에 배점을 매겨 합산하는 학과(패턴 ⑬)는 scoringMethod가
  // POINT_ACCUMULATION이고 scoreItems/pointThreshold를 쓴다. 그 외엔 PASS_FAIL + comprehensiveExam.
  scoringMethod     ScoringMethod @default(PASS_FAIL) @map("scoring_method")
  comprehensiveExam Json?         @map("comprehensive_exam")
  scoreItems        Json?         @map("score_items")
  pointThreshold    Int?          @map("point_threshold")

  mandatoryRequirements Json?   @map("mandatory_requirements")
  substitutionRules     Json    @default("[]") @map("substitution_rules")
  languageScoreStandard Json?   @map("language_score_standard")
  thesisOptional        Boolean @default(false) @map("thesis_optional")
  // "대체시_트랙제한" 원문 — 대체 옵션이 특정 트랙에만 열려있는 경우(예: mtc 자격증 대체는 미디어공학트랙 전용).
  trackRestrictionNote  String? @map("track_restriction_note")

  // 데이터 신뢰도(패턴 ⑮) — Claude Code 세션이 catholic.ac.kr 403 차단 상태에서 WebSearch 스니펫만으로
  // 조사한 행은 verified:false + dataSource:SEARCH_SNIPPET. 페이지 자체에 정보가 없던 학과(⑩)는 NOT_FOUND,
  // 첨부파일 안에만 있는 학과(⑰)는 NOTICE_ATTACHMENT, 신설학과라 요건 자체가 없는 경우(⑲)는 NOT_YET_ESTABLISHED.
  dataSource    RequirementDataSource @default(PAGE_DIRECT) @map("data_source")
  verified      Boolean               @default(true) @map("verified")
  sourceUrl     String?               @map("source_url")
  attachmentUrl String?               @map("attachment_url")
  notes         String?               @map("notes")

  department Department @relation(fields: [departmentId], references: [id])
  track      Track?     @relation(fields: [trackId], references: [id])

  @@index([departmentId])
  @@index([trackId])
  @@map("catalog_graduation_requirements")
}

enum RequirementScope {
  ALL
  FIRST_MAJOR
  DOUBLE_MAJOR
}

enum RequirementBasis {
  ADMISSION_YEAR
  GRADUATION_DATE
}

enum RequirementDataSource {
  PAGE_DIRECT
  NOTICE_ATTACHMENT
  SEARCH_SNIPPET
  NOT_FOUND
  NOT_YET_ESTABLISHED
}

enum ScoringMethod {
  PASS_FAIL
  POINT_ACCUMULATION
}

model CatalogCatholicCheck {
  id           Int    @id @default(autoincrement())
  universityId Int    @map("university_id")
  key          String
  label        String
  // Course.name에 이 중 하나라도 포함되면 자동 이수로 판정한다(신/구 과목명 별칭 포함, 예:
  // 그리스도교사상과문화 ↔ 영성). 자동감지는 제안일 뿐이고 GraduationExtra.catholicChecks에
  // 사용자가 명시적으로 남긴 값이 항상 우선한다.
  matchPatterns String[] @default([]) @map("match_patterns")
  credit        Int?
  // 기초교양필수/중핵교양선택필수 중 어느 쪽 합계에 잡히는 항목인지(SummaryGauge 공통교양 카드
  // 계산용). null이면 학점 집계 대상이 아닌 정보성 체크(예: 학점 미확정 항목).
  creditGroup String? @map("credit_group") // 'BASIC' | 'CORE'
  // null=전체 학번 적용. I-DESIGN/Career-DESIGN처럼 특정 학번부터 신설된 항목에만 사용.
  admissionYearFrom Int?                  @map("admission_year_from")
  // null=이후 학번도 계속 적용. 키스톤디자인처럼 특정 학번부터 항목 구성 자체가 바뀌는 경우
  // (2024학번부터 인문창의/창의설계 2과목 → 단일 3학점 과목) 이전 항목의 상한을 명시하는 데 쓴다.
  admissionYearTo   Int?                  @map("admission_year_to")
  dataSource        RequirementDataSource @default(PAGE_DIRECT) @map("data_source")
  verified          Boolean               @default(true)
  sourceUrl         String?               @map("source_url")
  university        University            @relation(fields: [universityId], references: [id])

  @@index([universityId])
  @@map("catalog_catholic_checks")
}

model RetakeGroup {
  id             Int     @id @default(autoincrement())
  profileId      Int     @map("profile_id")
  groupKey       String  @map("group_key")
  name           String
  retakeAccepted Boolean @default(true) @map("retake_accepted")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, groupKey])
  @@map("retake_groups")
}

model GraduationExtra {
  profileId        Int     @id @map("profile_id")
  languageScore    Int?    @map("language_score")
  // languageScoreStandard가 학과마다 시험 종류(TOEIC/TOEFL_IBT/NEW_TEPS/JPT/IELTS 등)가 다른 JSON이라
  // 어떤 시험 점수인지 같이 저장해야 기준점 비교가 가능하다.
  languageExamType String? @map("language_exam_type")
  thesisPass       Boolean @default(false) @map("thesis_pass")
  catholicChecks   Json    @default("{}") @map("catholic_checks")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("graduation_extra")
}
