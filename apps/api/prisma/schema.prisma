// 초안 스키마 — [[구현 방식]] 4.1 참고. Phase 1 최소 테이블만 정의, 실제 마이그레이션은 이후 이슈에서 진행.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id              Int                    @id @default(autoincrement())
  name            String
  supported       Boolean                @default(false)
  departments     Department[]
  colleges        College[]
  profiles        Profile[]
  catalogChecks   CatalogCatholicCheck[]
  courseOfferings CourseOffering[]

  @@map("universities")
}

// 계열(College)은 학과 상위 그룹핑 단위 — 대학 공식 계열번호를 그대로 id로 사용(autoincrement 아님).
// 크롤러가 학과 사이트 URL을 발견/조직하는 데 쓰인다([[대학_학사_데이터_크롤링_파이프라인_및_폐지_과목_처리_설계서_v2]] 1.2).
model College {
  id           Int          @id
  universityId Int          @map("university_id")
  name         String
  campus       String       @default("성심") // '성심' | '성의' | '성신'
  university   University   @relation(fields: [universityId], references: [id])
  departments  Department[]

  @@index([universityId])
  @@map("colleges")
}

model Department {
  id                     Int                            @id @default(autoincrement())
  universityId           Int                            @map("university_id")
  collegeId              Int?                           @map("college_id")
  name                   String
  catalogReady           Boolean                        @default(false) @map("catalog_ready")
  // 아래 3개 필드는 catalog/catholic-university 크롤러가 학과 사이트를 찾아가는 데 쓰는 실제 확인된 값
  // ([[대학_학사_데이터_크롤링_파이프라인_및_폐지_과목_처리_설계서_v2]] 1.3, 가톨릭대_학과_계열_매핑.xlsx 기준).
  domainSlug             String?                        @map("domain_slug")
  baseUrl                String?                        @map("base_url")
  urlPattern             String                         @default("standard") @map("url_pattern") // 'standard' | 'subdirectory' | 'other-campus'
  university             University                     @relation(fields: [universityId], references: [id])
  college                College?                       @relation(fields: [collegeId], references: [id])
  tracks                 Track[]
  catalogCourses         CatalogCourse[]
  graduationRequirements CatalogGraduationRequirement[]
  majorProfiles          Profile[]                      @relation("MajorDepartment")
  secondMajorProfiles    Profile[]                      @relation("SecondMajorDepartment")
  minorProfiles          Profile[]                      @relation("MinorDepartment")

  @@index([universityId])
  @@index([collegeId])
  @@map("departments")
}

model Track {
  id                       Int        @id @default(autoincrement())
  departmentId             Int        @map("department_id")
  name                     String
  requiredCourseCount      Int        @map("required_course_count")
  department               Department @relation(fields: [departmentId], references: [id])
  majorTrackProfiles       Profile[]  @relation("MajorTrack")
  secondMajorTrackProfiles Profile[]  @relation("SecondMajorTrack")

  @@index([departmentId])
  @@map("tracks")
}

enum ProgramType {
  DOUBLE_MAJOR // 복수전공(제2전공)
  DEEPENED_MAJOR // 전공심화(단수전공)
}

model Profile {
  id            Int    @id @default(autoincrement())
  sessionId     String @unique @map("session_id")
  admissionYear Int    @map("admission_year")
  universityId  Int    @map("university_id")

  majorDepartmentId Int         @map("major_department_id")
  majorTrackId      Int?        @map("major_track_id")
  programType       ProgramType @map("program_type")

  secondMajorDepartmentId Int? @map("second_major_department_id")
  secondMajorTrackId      Int? @map("second_major_track_id")

  minorDepartmentId Int?    @map("minor_department_id")
  hasMicroDegree    Boolean @default(false) @map("has_micro_degree")

  syncedAt DateTime? @map("synced_at")

  university            University  @relation(fields: [universityId], references: [id])
  majorDepartment       Department  @relation("MajorDepartment", fields: [majorDepartmentId], references: [id])
  majorTrack            Track?      @relation("MajorTrack", fields: [majorTrackId], references: [id])
  secondMajorDepartment Department? @relation("SecondMajorDepartment", fields: [secondMajorDepartmentId], references: [id])
  secondMajorTrack      Track?      @relation("SecondMajorTrack", fields: [secondMajorTrackId], references: [id])
  minorDepartment       Department? @relation("MinorDepartment", fields: [minorDepartmentId], references: [id])

  semesters       Semester[]
  retakeGroups    RetakeGroup[]
  graduationExtra GraduationExtra?

  @@index([universityId])
  @@index([majorDepartmentId])
  @@index([secondMajorDepartmentId])
  @@index([minorDepartmentId])
  @@map("profiles")
}

model Semester {
  id        Int     @id @default(autoincrement())
  profileId Int     @map("profile_id")
  label     String
  sortOrder Int     @map("sort_order")
  active    Boolean @default(false)

  // Profile은 세션 단위 임시 데이터라, 세션 만료/탈퇴 시 하위 학기·과목도 함께 정리되어야 한다.
  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  courses Course[]

  @@index([profileId])
  @@map("semesters")
}

enum CourseSource {
  CRAWL
  TEXT_PASTE
  MANUAL
}

model Course {
  id                          Int          @id @default(autoincrement())
  semesterId                  Int          @map("semester_id")
  name                        String
  code                        String?
  category                    String?
  credit                      Int
  general                     Boolean      @default(false)
  substitutionCatalogCourseId Int?         @map("substitution_catalog_course_id")
  source                      CourseSource @default(MANUAL)
  // CourseOffering 매칭 시점의 "개설전공(과)" 원문(FEAT#19). 졸업계산에서 중핵교양필수 과목이
  // 학생 본인 전공 소속으로 개설된 경우 전공학점으로 재분류하는 데 쓰인다(Department FK 아님,
  // CourseOffering과 동일하게 원문 텍스트로만 보관 — 요청 시점 매칭이라 학과가 나중에 바뀌어도 안전).
  offeringDepartmentName      String?      @map("offering_department_name")
  // CourseOffering의 "외국어 강의여부" 원문(예: "A형(영)") — 외국어로 진행되는 강의임을 STEP1에 표시.
  foreignLanguageType         String?      @map("foreign_language_type")

  semester     Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  // 대체인정 연결된 요람 과목이 삭제되어도 수강기록 자체는 남기고 연결만 해제한다.
  substitution CatalogCourse? @relation(fields: [substitutionCatalogCourseId], references: [id], onDelete: SetNull)

  @@index([semesterId])
  @@index([substitutionCatalogCourseId])
  @@map("courses")
}

model CatalogCourse {
  id                Int    @id @default(autoincrement())
  departmentId      Int    @map("department_id")
  name              String
  code              String
  category          String
  credit            Int
  admissionYearFrom Int    @map("admission_year_from")
  admissionYearTo   Int?   @map("admission_year_to")

  department         Department @relation(fields: [departmentId], references: [id])
  substitutedCourses Course[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("catalog_courses")
}

// 트리니티(uportal) 학기별 개설과목 리스트 엑셀을 수동 임포트한 데이터([[issue/[FEAT#19] 크롤링 과목 자동 과목코드 매칭 (요람 대조)]]).
// 요람(CatalogCourse)과 달리 "그 학기에 실제로 개설된 강좌"라 담당교수/분반이 있고, 같은 code를
// 여러 학과가 서로 다른 분반으로 공유 개설하는 경우도 있어 학과 FK 없이 원문 학과명만 저장한다.
// 에브리타임 크롤러가 과목코드/학점을 못 얻는 문제를 이 데이터와 (과목명 + 담당교수) 매칭으로 보완한다.
model CourseOffering {
  id                  Int     @id @default(autoincrement())
  universityId        Int     @map("university_id")
  year                Int
  term                String // '1학기' | '2학기' | '하계계절학기' | '동계계절학기'
  code                String
  name                String
  section             String
  professor           String
  credit              Int
  category            String
  departmentName      String  @map("department_name") // 엑셀 원문("개설전공(과)") 그대로, Department FK 아님
  foreignLanguageType String? @map("foreign_language_type") // 엑셀 "외국어 강의여부" 원문(예: "A형(영)"), 빈칸이면 null

  university University @relation(fields: [universityId], references: [id])

  @@unique([universityId, year, term, code, section])
  @@index([universityId, year, term, name])
  @@map("course_offerings")
}

// 실제 졸업요건은 "트랙별 필수과목 리스트"가 아니라 학과별 "졸업종합시험 + 대체규정" 구조라
// (심화전공/복수전공 과목 수, TOEIC/자격증/논문/공모전 대체 등 학과마다 상이) JSON 기반 반구조화 모델로 설계.
// comprehensiveExam/substitutionRules/creditBreakdown 형식은 구현 방식 문서·설계서 v2 참고.
model CatalogGraduationRequirement {
  id                Int  @id @default(autoincrement())
  departmentId      Int  @map("department_id")
  admissionYearFrom Int  @map("admission_year_from")
  admissionYearTo   Int? @map("admission_year_to")

  totalCreditMin        Int?    @map("total_credit_min")
  creditBreakdown       Json?   @map("credit_breakdown")
  comprehensiveExam     Json?   @map("comprehensive_exam")
  substitutionRules     Json    @default("[]") @map("substitution_rules")
  languageScoreStandard Json?   @map("language_score_standard")
  thesisOptional        Boolean @default(false) @map("thesis_optional")

  department Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, admissionYearFrom])
  @@index([departmentId])
  @@map("catalog_graduation_requirements")
}

model CatalogCatholicCheck {
  id           Int        @id @default(autoincrement())
  universityId Int        @map("university_id")
  key          String
  label        String
  university   University @relation(fields: [universityId], references: [id])

  @@index([universityId])
  @@map("catalog_catholic_checks")
}

model RetakeGroup {
  id             Int     @id @default(autoincrement())
  profileId      Int     @map("profile_id")
  groupKey       String  @map("group_key")
  name           String
  retakeAccepted Boolean @default(true) @map("retake_accepted")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, groupKey])
  @@map("retake_groups")
}

model GraduationExtra {
  profileId        Int     @id @map("profile_id")
  languageScore    Int?    @map("language_score")
  // languageScoreStandard가 학과마다 시험 종류(TOEIC/TOEFL_IBT/NEW_TEPS/JPT/IELTS 등)가 다른 JSON이라
  // 어떤 시험 점수인지 같이 저장해야 기준점 비교가 가능하다.
  languageExamType String? @map("language_exam_type")
  thesisPass       Boolean @default(false) @map("thesis_pass")
  catholicChecks   Json    @default("{}") @map("catholic_checks")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("graduation_extra")
}
