# 실제 값을 채운 뒤 이 파일을 deployment/env/.env 로 복사해서 사용하세요.
# deployment/env/.env 는 .gitignore의 ".env" 규칙에 걸려 자동으로 커밋되지 않습니다.

POSTGRES_PASSWORD=changeme
# db는 docker-compose 서비스명(내부 DNS) — localhost 아님
DATABASE_URL=postgresql://postgres:changeme@db:5432/canyougraduate?schema=public

PORT=4000
CORS_ORIGIN=https://your-canyougraduate-domain.com

# next build 시점에 클라이언트 번들에 굳어지는 값 — docker-compose.prod.yml의 build.args로 전달됨
NEXT_PUBLIC_API_URL=https://api.your-canyougraduate-domain.com
